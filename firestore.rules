rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /app_data/availability {
      allow read: if true;
      allow write: if false;
    }

    match /app_data/staff_access {
      allow read: if true;
      allow write: if false;
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll([
          'repName',
          'day',
          'startTime',
          'endTime',
          'name',
          'email',
          'field',
          'bookedAt'
        ]) &&
        request.resource.data.repName is string &&
        request.resource.data.day is string &&
        request.resource.data.startTime is string &&
        request.resource.data.endTime is string &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.field is string &&
        request.resource.data.bookedAt is string;
      allow update: if false;
      allow delete: if true;
    }
  }
}
